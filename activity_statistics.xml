<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_statistics.xml
  Statistics calculator layout. User enters numbers separated by commas
  and the results card shows all statistical measures.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_primary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"
            app:titleTextColor="@color/text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter Dataset"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent_blue"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="e.g.  4, 7, 2, 9, 4, 1, 8"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDataset"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:imeOptions="actionDone"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/roboto_mono" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Separate values with commas, spaces, or semicolons"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSampleData"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="Sample"
                    android:textSize="13sp"
                    app:strokeColor="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="Clear"
                    android:textSize="13sp"
                    app:strokeColor="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="48dp"
                    android:text="Calculate"
                    android:backgroundTint="@color/accent_orange"
                    android:textColor="@color/white" />

            </LinearLayout>

            <!-- Dataset info row -->
            <TextView
                android:id="@+id/tvDatasetInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Error -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/error_color"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Results Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Statistical Results"
                        android:textColor="@color/accent_orange"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Count & Sum -->
                    <include layout="@layout/item_stat_row"
                        android:id="@+id/rowCount" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Count (n)" android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                        <TextView android:id="@+id/tvCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:textSize="16sp"
                            android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Sum (Σx)" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvSum" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="16sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="10dp" />

                    <!-- Mean -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Mean (μ)" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMean" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/accent_blue"
                            android:textSize="18sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Median -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Median" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMedian" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/accent_blue"
                            android:textSize="18sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Mode -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Mode" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMode" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/accent_blue"
                            android:textSize="14sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold"
                            android:gravity="end" android:maxWidth="220dp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="10dp" />

                    <!-- Std Dev -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Std Dev (σ, pop.)" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvStdDev" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/accent_green"
                            android:textSize="18sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Sample Std Dev -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Std Dev (s, sample)" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvSampleStdDev" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/accent_green"
                            android:textSize="18sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="10dp" />

                    <!-- Min, Max, Range -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Min" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMin" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="16sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Max" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMax" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="16sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Range" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvRange" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="16sp" android:fontFamily="@font/roboto_mono" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
